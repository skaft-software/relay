{
  "name": "relay",
  "version": "0.1.0",
  "description": "Lightweight OpenAI/Anthropic-compatible gateway for local llama.cpp models.",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --experimental-strip-types src/main.ts",
    "start": "node --env-file=.env --experimental-strip-types src/main.ts",
    "build": "npm run typecheck",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "smoke:openai": "node --env-file=.env --experimental-strip-types scripts/smoke-openai.ts",
    "smoke:anthropic": "node --env-file=.env --experimental-strip-types scripts/smoke-anthropic.ts",
    "check:local": "npm test && npm run build",
    "verify": "npm run check:local",
    "doctor": "node --env-file=.env --experimental-strip-types scripts/doctor.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.3"
  }
}
