# Relay server bind settings
HOST=127.0.0.1
PORT=1234

# Upstream local model API root (must include /v1)
UPSTREAM_BASE_URL=http://127.0.0.1:8080/v1

# Running context size of the upstream (--ctx-size in llama.cpp). Relay
# annotates /v1/models and /relay/capabilities so clients discover the
# real context window instead of the model-baked n_ctx_train value.
UPSTREAM_CTX_SIZE=

# Optional default model used when client omits model
DEFAULT_MODEL=

# Request/response limits and timing
REQUEST_TIMEOUT_SECONDS=600
MAX_REQUEST_BODY_BYTES=1048576
COMPLETION_TTL_SECONDS=3600

# Startup behavior
RELAY_PROBE_ON_STARTUP=true
RELAY_STRICT_STARTUP=false
RELAY_PROBE_TIMEOUT_MS=3000

# Compatibility/normalization controls
RELAY_UNKNOWN_FIELD_POLICY=pass_through
RELAY_STRICT_COMPAT=false
RELAY_WARN_ON_STRIPPED_FIELDS=true
RELAY_MODEL_PROFILE=generic
RELAY_REASONING_MODE=off
RELAY_TOOL_MODE=auto

# Thinking (brainstorming) support for agents that probe capabilities.
# Set RELAY_THINKING_SUPPORTED=true when the upstream model supports a
# thinking/reasoning mode. Use RELAY_THINKING_LEVELS to declare which
# levels are available (comma-separated, default "on,off").
# For llama.cpp models with binary thinking controls use "on,off".
RELAY_THINKING_SUPPORTED=false
RELAY_THINKING_LEVELS=on,off

# Optional sampling defaults
DEFAULT_TEMPERATURE=
DEFAULT_TOP_P=
DEFAULT_TOP_K=
DEFAULT_MIN_P=
DEFAULT_PRESENCE_PENALTY=
DEFAULT_REPETITION_PENALTY=

# Observability/logging
RELAY_OBSERVABILITY_ENABLED=true
RELAY_REQUEST_HISTORY_LIMIT=100
RELAY_LOG_PROMPTS=false
LOG_LEVEL=info

# Optional Relay auth key. If set, clients must send matching bearer/x-api-key.
API_KEY=change-me-in-production

# Security hardening
CORS_ORIGIN=
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RELAY_EXPOSE_UPSTREAM_ERRORS=false

# CAUTION: RELAY_DEBUG_TRUNCATION_CONTENT=1 logs raw prompt previews.
# Only enable for local debugging with trusted log storage.
# RELAY_DEBUG_TRUNCATION=1
# RELAY_DEBUG_TRUNCATION_CONTENT=1

# Lazy model lifecycle (default: disabled, behavior unchanged).
# When enabled, Relay can start the upstream llama.cpp process on demand and
# stop it after an idle period so GPU memory is not held 24/7.
# Leave RELAY_MODEL_LIFECYCLE_ENABLED=false for the current always-on behavior.
RELAY_MODEL_LIFECYCLE_ENABLED=false
# Shell command that starts the upstream model server (e.g. llama-server).
# This value is treated as a secret: it is never logged verbatim.
RELAY_MODEL_START_COMMAND=
# Shell command that stops the upstream model server (e.g. pkill -f llama-server).
RELAY_MODEL_SHUTDOWN_COMMAND=
# Optional explicit health URL. Falls back to UPSTREAM_BASE_URL/health then /v1/models.
RELAY_MODEL_HEALTH_URL=
# Idle shutdown timeout in milliseconds (default 600000 = 10 minutes).
RELAY_MODEL_IDLE_SHUTDOWN_MS=600000
# Maximum time to wait for the model to become healthy after starting.
RELAY_MODEL_START_TIMEOUT_MS=120000

# ---- Lifecycle model control (argv form) ----
# Alternative to RELAY_MODEL_START_COMMAND / RELAY_MODEL_SHUTDOWN_COMMAND.
# Supply a JSON array of string arguments (no shell interpretation).
# If set, these take precedence over the shell-command form.
# RELAY_MODEL_START_ARGV='["llama-server","--host","0.0.0.0","--port","8080"]'
# RELAY_MODEL_SHUTDOWN_ARGV='["pkill","-f","llama-server"]'

# ---- Lifecycle circuit breaker ----
# Prevents rapid restart loops when the model repeatedly fails to start.
# After threshold failures in the window, the breaker enters cooldown.
RELAY_LIFECYCLE_CIRCUIT_BREAKER_THRESHOLD=3
RELAY_LIFECYCLE_CIRCUIT_BREAKER_WINDOW_MS=300000
RELAY_LIFECYCLE_CIRCUIT_BREAKER_COOLDOWN_MS=120000

# ---- Lifecycle diagnostics ----
# Ring buffer size (bytes) for capturing child process stdout/stderr.
RELAY_LIFECYCLE_RING_BUFFER_BYTES=65536
# Maximum time to wait for health endpoint to go red after issuing shutdown.
RELAY_LIFECYCLE_SHUTDOWN_CONFIRM_TIMEOUT_MS=10000

# ---- Job queue ----
# Maximum pending (queued) jobs; further submissions get 429.
RELAY_JOB_QUEUE_MAX_PENDING=100
# TTL for completed/failed job entries (seconds).
RELAY_JOB_TTL_SECONDS=3600

# ---- Graceful shutdown ----
# Maximum time to wait for active jobs to finish before forced exit.
RELAY_SHUTDOWN_TIMEOUT_MS=30000

# ---- Response store byte cap ----
# Optional maximum total bytes for cached completion/response stores.
# Omit or leave empty to cap only by entry count.
# MAX_STORE_BYTES=67108864

# ---- Rate limiting for relay POST endpoints ----
# Separate rate limit for POST /relay/jobs (distinct from auth endpoints).
RATE_LIMIT_RELAY_POST_MAX=50
RATE_LIMIT_RELAY_POST_WINDOW_SECONDS=60

# ---- Misc ----
# Capture request/response bodies in observability data (default false).
RELAY_OBSERVABILITY_CAPTURE_BODY=false
# Trust X-Forwarded-For etc. when running behind a reverse proxy.
TRUST_PROXY=false
